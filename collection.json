{
  "info": {
    "name": "Pilgrim System API",
    "_postman_id": "12345678-1234-1234-1234-123456789012",
    "description": "Admins + Mobile APIs",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000"
    },
    {
      "key": "access_token",
      "value": ""
    },
    {
      "key": "refresh_token",
      "value": ""
    },
    {
      "key": "admin_id",
      "value": ""
    },
    {
      "key": "pilgrim_id",
      "value": ""
    },
    {
      "key": "session_id",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Admins Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin1\",\n  \"password\": \"123456\"\n}"
            },
            "url": "{{base_url}}/api/admins/auth/login"
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}"
            },
            "url": "{{base_url}}/api/admins/auth/refresh-token"
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}"
            },
            "url": "{{base_url}}/api/admins/auth/logout"
          }
        }
      ]
    },
    {
      "name": "Admins Users",
      "item": [
        {
          "name": "Get Admins",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": "{{base_url}}/api/admins/users"
          }
        },
        {
          "name": "Create Admin",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin2\",\n  \"password\": \"123456\",\n  \"role\": \"STAFF\"\n}"
            },
            "url": "{{base_url}}/api/admins/users"
          }
        },
        {
          "name": "Block Admin",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": "{{base_url}}/api/admins/users/{{admin_id}}/block"
          }
        }
      ]
    },
    {
      "name": "Pilgrims (Admin)",
      "item": [
        {
          "name": "Get Pilgrims",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": "{{base_url}}/api/admins/pilgrims"
          }
        },
        {
          "name": "Create Pilgrim",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"Ali Valiyev\",\n  \"phone\": \"+998901234567\",\n  \"country_id\": \"UUID\",\n  \"passport_number\": \"AA123456\"\n}"
            },
            "url": "{{base_url}}/api/admins/pilgrims"
          }
        }
      ]
    },
    {
      "name": "Mobile Auth",
      "item": [
        {
          "name": "Send OTP",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"+998901234567\",\n  \"method\": \"SMS\"\n}"
            },
            "url": "{{base_url}}/api/mobile/auth/send-otp"
          }
        },
        {
          "name": "Verify OTP",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"+998901234567\",\n  \"code\": \"123456\",\n  \"session_id\": \"{{session_id}}\"\n}"
            },
            "url": "{{base_url}}/api/mobile/auth/verify-otp"
          }
        },
        {
          "name": "Register (Manual)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"MANUAL\",\n  \"full_name\": \"Ali Valiyev\",\n  \"phone\": \"+998901234567\",\n  \"country_id\": \"UUID\"\n}"
            },
            "url": "{{base_url}}/api/mobile/auth/register"
          }
        },
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": "{{base_url}}/api/mobile/me"
          }
        }
      ]
    }
  ]
}